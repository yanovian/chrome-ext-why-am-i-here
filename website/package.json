{
  "name": "why-am-i-here-website",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/copy-assets.mjs",
    "predev": "node scripts/copy-assets.mjs",
    "og-images": "node scripts/copy-assets.mjs && node scripts/build-og-image.mjs && node scripts/copy-assets.mjs",
    "dev": "vite",
    "lint-i18n": "node scripts/lint-i18n.mjs",
    "lint-i18n-fix": "node scripts/lint-i18n.mjs --fix",
    "build": "pnpm lint-i18n && tsc --noEmit && vite build && node --experimental-strip-types scripts/prerender-locale-html.mjs",
    "preview": "vite preview --host --base /chrome-ext-why-am-i-here/"
  },
  "dependencies": {
    "@unhead/react": "^2.1.15",
    "@unhead/schema-org": "^2.1.15",
    "country-flag-icons": "^1.6.20",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "marked": "^18.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-plugin-html": "^3.2.2"
  }
}
