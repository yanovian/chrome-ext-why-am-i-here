    "i18next-browser-languagedetector": "^8.2.1",
    "marked": "^18.0.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-html": "^3.2.2"
  }
